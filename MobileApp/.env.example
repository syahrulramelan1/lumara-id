# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE
# LOCAL: file:./dev.db (SQLite)
# PRODUCTION: postgresql://user:pass@host:5432/dbname (Supabase)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DATABASE_URL="file:./dev.db"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SUPABASE — isi dari Project Settings > API
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJxxxx..."
SUPABASE_SERVICE_ROLE_KEY="eyJxxxx..."

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APP CONFIG
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_APP_URL="https://lumara-id.onrender.com"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ADMIN SECRET — match VITE_ADMIN_SECRET in Admin-Panel
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ADMIN_SECRET="your-strong-admin-secret"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RAJA ONGKIR (Starter) — hitung provinsi/kota/ongkir
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API key dari akun Raja Ongkir (Starter).
RAJAONGKIR_API_KEY=""
# Kota asal pengemasan (city_id di master Raja Ongkir). Titik jual tidak ditampilkan di website;
# hanya dipakai server untuk parameter `origin`. Sesuaikan dengan lokasi gudang (mis. zona Jakarta Timur).
# Contoh fallback bawaan kode: 152 — verifikasi di dashboard Raja Ongkir / trial cost untuk alamatmu.
RAJAONGKIR_ORIGIN_CITY_ID="152"
