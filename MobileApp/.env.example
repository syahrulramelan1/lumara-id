# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE
# LOCAL: file:./dev.db (SQLite)
# PRODUCTION: postgresql://user:pass@host:5432/dbname (Supabase)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DATABASE_URL="file:./dev.db"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SUPABASE — isi dari Project Settings > API
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJxxxx..."
SUPABASE_SERVICE_ROLE_KEY="eyJxxxx..."

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APP CONFIG
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_APP_URL="https://lumara-id.onrender.com"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ADMIN SECRET — match VITE_ADMIN_SECRET in Admin-Panel
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ADMIN_SECRET="your-strong-admin-secret"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RAJA ONGKIR (Komerce) — hitung provinsi/kota/ongkir
# Endpoint baru: https://rajaongkir.komerce.id/api/v1/ (Starter lama dead).
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API key dari akun Komerce (key Starter lama tetap kepake).
RAJAONGKIR_API_KEY=""
# Kota asal pengemasan (city_id Komerce — BUKAN ID Starter lama!).
# Titik jual tidak ditampilkan di website, hanya dipakai server sebagai `origin`.
# Referensi DKI Jakarta: 135=Jakbar, 136=Jaksel, 137=Jakpus, 138=Jakut, 139=Jaktim, 141=Kep. Seribu.
# Cari ID kota lain via: GET /api/shipping/cities?province_id=<id>
RAJAONGKIR_ORIGIN_CITY_ID="139"
